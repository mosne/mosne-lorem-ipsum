{
  "manifest_version": 3,
  "name": "Mosne Lorem Ipsum",
  "version": "1.0.0",
  "description": "Quickly copy Lorem Ipsum text and automatically insert it into the active input field or editable area.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}